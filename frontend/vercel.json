{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "framework": "vite",
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "rewrites": [
    {
      "source": "/v1/:path*",
      "destination": "https://aethon-production-3f5a.up.railway.app/v1/:path*"
    },
    {
      "source": "/ws",
      "destination": "https://aethon-production-3f5a.up.railway.app/ws"
    },
    { "source": "/(.*)", "destination": "/index.html" }
  ]
}
