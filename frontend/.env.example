# ── Local dev (copy to .env.local) ─────────────────────────────────────────
# Leave VITE_API_URL unset or use /v1 — Vite proxies to localhost:3001
# VITE_API_URL=/v1
# VITE_WS_URL=
# VITE_API_KEY=dev-api-key

# ── Production (Vercel / hosted frontend) ─────────────────────────────────
# Backend base URL WITHOUT trailing slash; /v1 is appended automatically
VITE_API_URL=https://YOUR-BACKEND-URL
# Optional if different from API host; derived from VITE_API_URL when omitted
VITE_WS_URL=wss://YOUR-BACKEND-URL/ws
VITE_API_KEY=dev-api-key

# ── Somnia wallet (Connect button) ──────────────────────────────────────────
VITE_SOMNIA_CHAIN_ID=50312
VITE_SOMNIA_RPC_URL=https://dream-rpc.somnia.network
VITE_SOMNIA_EXPLORER=https://shannon-explorer.somnia.network
# When using production API locally, match Railway SIWE_DOMAIN / SIWE_URI
# VITE_SIWE_DOMAIN=aethon-lemon.vercel.app
# VITE_SIWE_URI=https://aethon-lemon.vercel.app
