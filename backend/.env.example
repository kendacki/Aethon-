# Database
DATABASE_URL=postgresql://aethon:aethon@localhost:5432/aethon
# Run migrations via `npm run db:migrate` (CI/CD / Railway preDeploy). Local dev only:
# RUN_MIGRATIONS_ON_BOOT=true
# Optional pgvector for hybrid RAG (falls back to full-text search if unavailable):
# PGVECTOR_ENABLED=true

# Indexer
INDEXER_START_BLOCK=0
INDEXER_INTERVAL_MS=12000
INDEXER_BATCH_BLOCKS=1000

# Relayer (defaults to AGENT_PRIVATE_KEY or DEPLOYER_PK)
RELAYER_PRIVATE_KEY=

# API security — include your Vercel frontend URL
CORS_ORIGIN=https://aethon-lemon.vercel.app,http://localhost:5173,http://localhost:3000
RATE_LIMIT_RPM=500
API_PORT=3001
API_KEY=dev-api-key

# Web3 auth (SIWE / EIP-4361)
JWT_SECRET=change-me-to-a-long-random-string
JWT_EXPIRES_IN=24h
# Optional: lock SIWE domain/uri in production (comma-separated for multiple origins)
SIWE_DOMAIN=aethon-lemon.vercel.app,localhost:5173
SIWE_URI=https://aethon-lemon.vercel.app,http://localhost:5173

# Somnia network
SOMNIA_RPC_URL=https://dream-rpc.somnia.network
SOMNIA_WS_URL=wss://ws.somnia.network
SOMNIA_CHAIN_ID=50312
SOMNIA_EXPLORER=https://shannon-explorer.somnia.network

# Contract addresses — from deployments/somniaTestnet-50312.json after deploy
REPUTATION_ENGINE_ADDR=0x4949e8D1cc21dd5A10120738Dff4E0fDE7C29cab
CIRCUIT_BREAKER_ADDR=0xaAA01CF5C744FBF0aDfc564c9b520782A50757C0
AGENT_REGISTRY_ADDR=0xA2BAdcce7612cC5729B6df596c660A738b94b60e
COALITION_MANAGER_ADDR=0x6e56476d64e6C324b2b1c92149466dF3aD76cE4B
TASK_MARKET_ADDR=0x81Ccc866471FA1681F365E9a3c453C2fbD9886d8

# Deployment keys (never commit real values)
DEPLOYER_PK=
DEPLOYER_ADDR=
GUARDIAN_MULTISIG_ADDR=
TREASURY_ADDR=
SLASH_MULTISIG_ADDR=

# Agent runtime (optional)
AGENT_PRIVATE_KEY=
AGENT_TYPE=ARBITRAGE
AGENT_STAKE_WEI=500000000000000000

# Agent ↔ API (required for skill execution + coalition coordination)
API_BASE_URL=http://localhost:3001/v1
API_PUBLIC_URL=http://localhost:3001

# Fleet health (local dev / mirrors production Railway API)
# AGENT_HEALTH_URLS={"ARBITRAGE":"https://aethon-agent-arbitrage-production.up.railway.app",...}
FLEET_HEALTH_URLS_FILE=env/fleet.health-urls.production.json

# Somnia-native features
SOMNIA_AGENTS_ENABLED=true
REACTIVITY_ENABLED=true
DATA_STREAMS_ENABLED=true

# Somnia platform agents (validator-consensus compute) — https://docs.somnia.network/agents
# Deploy consumer: npm run deploy:somnia-consumer
SOMNIA_AGENTS_PLATFORM_ADDR=0x037Bb9C718F3f7fe5eCBDB0b600D607b52706776
SOMNIA_AGENT_CONSUMER_ADDR=0xe542f4bE7Ae4c3BD7A6bC3EC5B6c4701Da74D353
# Base agent IDs (same on testnet + mainnet)
SOMNIA_JSON_API_AGENT_ID=13174292974160097713
SOMNIA_LLM_AGENT_ID=12847293847561029384
# Optional Somnia ADP peer discovery (defaults to API registry)
# SOMNIA_ADP_HOST=http://127.0.0.1:9090
SOMNIA_REQUEST_TIMEOUT_MS=90000

# Somnia Agent Kit registry (discovery / Agentathon) — https://somnia-agent-kit.gitbook.io/
SOMNIA_KIT_REGISTRY_ADDR=0xC9f3452090EEB519467DEa4a390976D38C008347

# AETHON fleet vault (Kit-compatible reserve per agent — deploy: npm run deploy:aethon-vault)
# SOMNIA_VAULT_ENABLED=true
# AETHON_FLEET_VAULT_ADDR=
# SOMNIA_VAULT_DAILY_LIMIT_STT=10
# SOMNIA_VAULT_MIN_BALANCE_WEI=100000000000000000

# Safety thresholds
MAX_GAS_PER_TX=5000000
MIN_REPUTATION=50
CIRCUIT_BREAKER_THRESHOLD=3
WATCHDOG_INTERVAL_MS=5000
