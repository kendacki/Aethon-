TASK_MARKET_ADDR=0x8C9D76B82fB7bd5D56061CfA0Df0983028f314Fc
AETHON_FLEET_VAULT_ADDR=0x71bb54c9507387B716199D72858a1F4DEB8FfE1b
SWARM_EXECUTION_ROUTER_ADDR=0x71bb54c9507387B716199D72858a1F4DEB8FfE1b
