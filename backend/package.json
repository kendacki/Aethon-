{
  "name": "aethon-backend",
  "version": "3.0.0",
  "description": "AETHON v3.0 — Agent Runtime, REST API, WebSocket, and Somnia contract tooling",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "tsc -p tsconfig.json && node scripts/copy-assets.cjs",
    "dev:api": "tsx watch src/api/server.ts",
    "dev:agent": "tsx watch src/agent/index.ts",
    "start:api": "node dist/api/server.js",
    "start:agent": "node dist/agent/index.js",
    "db:migrate": "tsx src/db/migrate.ts",
    "compile": "hardhat compile",
    "test:contracts": "hardhat test",
    "deploy:testnet": "hardhat run scripts/deploy_v3.cjs --network somniaTestnet",
    "deploy:local": "hardhat run scripts/deploy_v3.cjs --network hardhat"
  },
  "dependencies": {
    "cors": "^2.8.5",
    "dotenv": "^16.4.7",
    "ethers": "^6.13.5",
    "express": "^4.21.2",
    "express-rate-limit": "^7.5.0",
    "helmet": "^8.0.0",
    "jsonwebtoken": "^9.0.3",
    "pg": "^8.13.1",
    "siwe": "^3.0.0",
    "swagger-ui-express": "^5.0.1",
    "ws": "^8.18.0",
    "yaml": "^2.7.0",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@nomicfoundation/hardhat-ethers": "^3.0.8",
    "@nomicfoundation/hardhat-toolbox": "^5.0.0",
    "@openzeppelin/contracts": "^4.9.6",
    "@types/cors": "^2.8.17",
    "@types/express": "^5.0.0",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "^22.10.5",
    "@types/pg": "^8.11.10",
    "@types/swagger-ui-express": "^4.1.7",
    "@types/ws": "^8.5.13",
    "hardhat": "^2.22.17",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2"
  }
}
